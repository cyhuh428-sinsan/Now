# 공용 NowNote 서버 예시값입니다.
# 이 파일을 .env로 복사한 뒤 change-this-* 값을 모두 긴 랜덤 값으로 바꿉니다.
# 실제 .env 파일은 절대 Git에 올리지 않습니다.

NOW_SERVER_NAME=NowNote Public Server
NOW_API_TOKEN=change-this-api-token
NOW_USER_TOKEN_REQUIRED=true
NOW_POSTGRES_PASSWORD=change-this-postgres-password
NOW_DATABASE_URL=postgresql+psycopg://now:change-this-postgres-password@now-postgres:5432/now

NOW_STORAGE_DIR=/data/recordings
NOW_MESSENGER_STORAGE_DIR=/data/messenger
NOW_MESSENGER_MAX_UPLOAD_MB=10
NOW_MESSENGER_ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,gif,pdf,txt,md,docx,xlsx,pptx,zip
NOW_MESSENGER_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf,text/plain,text/markdown,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/zip,application/octet-stream
NOW_WORKER_POLL_SECONDS=5
NOW_WORKER_BATCH_SIZE=5

NOW_LLM_PROVIDER=local
NOW_OPENAI_API_KEY=
NOW_OPENAI_BASE_URL=https://api.openai.com/v1
NOW_OPENAI_MODEL=gpt-4o-mini

NOW_PUBLIC_BASE_URL=https://nownote.sinsan.kr
NOW_BEHIND_REVERSE_PROXY=true

NOW_SELF_REGISTRATION_ENABLED=true
NOW_SELF_ACCOUNT_DELETE_ENABLED=true

# 공용 서버 비밀번호 재설정용 메일 발송 설정입니다.
NOW_SMTP_HOST=smtp.example.com
NOW_SMTP_PORT=587
NOW_SMTP_USERNAME=change-this-smtp-username
NOW_SMTP_PASSWORD=change-this-smtp-password
NOW_SMTP_FROM=noreply@nownote.sinsan.kr
NOW_SMTP_USE_TLS=true
NOW_PASSWORD_RESET_CODE_MINUTES=30
