# 이 파일을 .env로 복사한 뒤 change-this-* 값을 모두 바꿔서 사용합니다.
# 실제 .env 파일은 절대 Git에 올리지 않습니다.

NOW_SERVER_NAME=NowNote Local Server

# 긴 랜덤 값을 생성해서 넣습니다. 앱 동기화 API와 운영 화면을 보호합니다.
NOW_API_TOKEN=change-this-api-token

# 개인 Docker 서버는 false로 시작합니다.
# 공용 서버 오픈 전에는 사용자별 토큰 검증을 true로 켭니다.
NOW_USER_TOKEN_REQUIRED=false

# 첫 docker compose up 전에 확정합니다. DB 볼륨 생성 뒤 변경하려면
# DB 비밀번호 마이그레이션 또는 볼륨 초기화가 필요합니다.
NOW_POSTGRES_PASSWORD=change-this-postgres-password

# docker-compose.yml은 NOW_POSTGRES_PASSWORD로 DB 연결 URL을 구성합니다.
# 서버를 Docker Compose 밖에서 직접 실행할 때만 아래 값을 별도로 사용합니다.
NOW_DATABASE_URL=postgresql+psycopg://now:change-this-postgres-password@now-postgres:5432/now

# 컨테이너 안에서 원본 녹음 파일을 저장할 경로입니다.
# docker-compose.yml의 now_recording_data 볼륨도 같은 경로에 붙습니다.
NOW_STORAGE_DIR=/data/recordings
NOW_MESSENGER_STORAGE_DIR=/data/messenger
NOW_MESSENGER_MAX_UPLOAD_MB=10
NOW_MESSENGER_ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,gif,pdf,txt,md,docx,xlsx,pptx,zip
NOW_MESSENGER_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf,text/plain,text/markdown,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/zip
NOW_WORKER_POLL_SECONDS=5
NOW_WORKER_BATCH_SIZE=5

NOW_LLM_PROVIDER=local
NOW_OPENAI_API_KEY=
NOW_OPENAI_BASE_URL=https://api.openai.com/v1
NOW_OPENAI_MODEL=gpt-4o-mini

# 공용 서버로 열 때 설정합니다. 개인 로컬 서버는 비워둬도 됩니다.
NOW_PUBLIC_BASE_URL=
NOW_BEHIND_REVERSE_PROXY=false

# 공용 Web 사용자는 관리자 개입 없이 직접 가입할 수 있습니다.
NOW_SELF_REGISTRATION_ENABLED=true
NOW_SELF_ACCOUNT_DELETE_ENABLED=true

# 비밀번호 재설정 메일 발송 설정입니다. 개인 서버에서는 비워둘 수 있습니다.
# 공용 서버로 열 때는 NOW_SMTP_HOST와 NOW_SMTP_FROM을 반드시 설정합니다.
NOW_SMTP_HOST=
NOW_SMTP_PORT=587
NOW_SMTP_USERNAME=
NOW_SMTP_PASSWORD=
NOW_SMTP_FROM=
NOW_SMTP_USE_TLS=true
NOW_PASSWORD_RESET_CODE_MINUTES=30
